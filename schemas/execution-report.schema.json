{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec2flow.dev/schemas/execution-report.schema.json",
  "title": "Spec2Flow Execution Report",
  "description": "Structured result for the automated-execution stage.",
  "type": "object",
  "required": ["taskId", "stage", "goal", "summary", "outcome", "commands"],
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "automated-execution"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "outcome": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "partial"]
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked", "skipped"]
          },
          "exitCode": {
            "type": "integer"
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "repositoryGaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repositoryGap"
      }
    }
  },
  "$defs": {
    "repositoryGap": {
      "type": "object",
      "required": ["code", "message", "recoverable"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "recoverable": {
          "type": "boolean"
        }
      }
    }
  }
}