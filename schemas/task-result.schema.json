{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec2flow.dev/schemas/task-result.schema.json",
  "title": "Spec2Flow Task Result",
  "description": "Defines the persisted receipt for one completed task result including artifact contract validation status.",
  "type": "object",
  "required": ["taskResult"],
  "additionalProperties": false,
  "properties": {
    "taskResult": {
      "type": "object",
      "required": [
        "taskId",
        "status",
        "executionStateRef",
        "notes",
        "artifacts",
        "artifactContract",
        "errors",
        "submittedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "ready", "in-progress", "blocked", "completed", "failed", "skipped"]
        },
        "executionStateRef": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "artifactContract": {
          "$ref": "#/$defs/artifactContractSummary"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/errorItem"
          }
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": ["id", "kind", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["log", "trace", "screenshot", "report", "bug-draft", "diff", "other"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "errorItem": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "recoverable": {
          "type": "boolean"
        }
      }
    },
    "artifactContractSummary": {
      "type": "object",
      "required": ["status", "expectedArtifacts", "presentArtifacts", "missingArtifacts"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not-applicable", "satisfied", "missing"]
        },
        "expectedArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "presentArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "missingArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}