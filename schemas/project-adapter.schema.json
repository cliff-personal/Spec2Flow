{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec2flow.dev/schemas/project-adapter.schema.json",
  "title": "Spec2Flow Project Adapter",
  "description": "Declares the minimum facts Spec2Flow needs to onboard a repository.",
  "type": "object",
  "required": ["spec2flow"],
  "additionalProperties": false,
  "properties": {
    "spec2flow": {
      "type": "object",
      "required": ["project", "docs", "services", "infrastructure", "tests"],
      "additionalProperties": false,
      "properties": {
        "project": {
          "type": "object",
          "required": ["name", "type"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "type": {
              "type": "string",
              "enum": [
                "single-app",
                "monorepo",
                "polyglot-monorepo",
                "frontend-only",
                "backend-only",
                "service-platform"
              ]
            },
            "defaultBranch": { "type": "string", "minLength": 1 },
            "owner": { "type": "string", "minLength": 1 }
          }
        },
        "docs": {
          "type": "object",
          "required": ["requirements", "architecture"],
          "additionalProperties": false,
          "properties": {
            "requirements": { "$ref": "#/$defs/pathList" },
            "architecture": { "$ref": "#/$defs/pathList" },
            "database": { "$ref": "#/$defs/pathList" },
            "operations": { "$ref": "#/$defs/pathList" },
            "api": { "$ref": "#/$defs/pathList" }
          }
        },
        "services": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/serviceDefinition" }
        },
        "infrastructure": {
          "type": "object",
          "required": ["bootstrap"],
          "additionalProperties": false,
          "properties": {
            "bootstrap": { "type": "string", "minLength": 1 },
            "stop": { "type": "string", "minLength": 1 },
            "compose": { "type": "string", "minLength": 1 },
            "seed": { "type": "string", "minLength": 1 }
          }
        },
        "tests": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseDir": { "type": "string", "minLength": 1 },
            "executionDir": { "type": "string", "minLength": 1 },
            "bugsDir": { "type": "string", "minLength": 1 }
          }
        },
        "generatedBy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tool": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "generatedAt": { "type": "string", "format": "date-time" }
          }
        }
      }
    }
  },
  "$defs": {
    "pathList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "serviceDefinition": {
      "type": "object",
      "required": ["path", "start"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "frontend",
            "backend",
            "admin-frontend",
            "admin-backend",
            "worker",
            "provider",
            "contract-runtime",
            "database",
            "cache",
            "other"
          ]
        },
        "start": { "type": "string", "minLength": 1 },
        "health": { "type": "string", "minLength": 1 },
        "install": { "type": "string", "minLength": 1 },
        "test": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "envFiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}