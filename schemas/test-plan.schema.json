{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec2flow.dev/schemas/test-plan.schema.json",
  "title": "Spec2Flow Test Plan",
  "description": "Structured planning artifact for the test-design stage.",
  "type": "object",
  "required": ["taskId", "stage", "goal", "summary", "cases"],
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "test-design"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "strategy": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "level", "priority"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "level": {
            "type": "string",
            "enum": ["smoke", "integration", "regression", "edge"]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "targetFiles": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}