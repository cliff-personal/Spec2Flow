{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec2flow.dev/schemas/evaluation-summary.schema.json",
  "title": "Spec2Flow Evaluation Summary",
  "description": "Structured acceptance artifact for the evaluation stage.",
  "type": "object",
  "required": ["taskId", "stage", "summary", "decision", "artifactRefs"],
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "evaluation"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["accepted", "rejected", "needs-repair"]
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}